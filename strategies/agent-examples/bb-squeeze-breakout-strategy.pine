// Strategy derived from pinescript-agents/examples/simple/bollinger-squeeze.pine for backtesting in pinescripts-collections.

//@version=6
strategy("BB Squeeze Breakout [Agent Example]", shorttitle="BBSqzStr", overlay=true, margin_long=100, margin_short=100, default_qty_type=strategy.percent_of_equity, default_qty_value=10, commission_type=strategy.commission.percent, commission_value=0.1)

bbLength = input.int(20, "BB Length", minval=1, group="Bands")
bbMult = input.float(2.0, "BB Multiplier", minval=0.1, step=0.1, group="Bands")
kcLength = input.int(20, "KC Length", minval=1, group="Keltner")
kcMult = input.float(1.5, "KC Multiplier", minval=0.1, step=0.1, group="Keltner")

useStop = input.bool(true, "Use ATR Stop / Target", group="Risk")
atrLen = input.int(14, "ATR Length", minval=1, group="Risk")
slMult = input.float(1.5, "Stop ATR Mult", minval=0.1, step=0.1, group="Risk")
tpMult = input.float(2.5, "Target ATR Mult", minval=0.1, step=0.1, group="Risk")
bullColorInput = input.color(#089981, "Bullish Color", group="Visuals")
bearColorInput = input.color(#f23645, "Bearish Color", group="Visuals")

basis = ta.sma(close, bbLength)
dev = bbMult * ta.stdev(close, bbLength)
bbUpper = basis + dev
bbLower = basis - dev
kcMA = ta.ema(close, kcLength)
kcRange = ta.atr(kcLength)
kcUpper = kcMA + kcRange * kcMult
kcLower = kcMA - kcRange * kcMult

squeeze = bbUpper < kcUpper and bbLower > kcLower
noSqueeze = bbUpper > kcUpper or bbLower < kcLower

donchianMid = (ta.highest(high, kcLength) + ta.lowest(low, kcLength)) / 2
momentum = close - donchianMid

releaseLong = noSqueeze and not noSqueeze[1] and momentum > 0
releaseShort = noSqueeze and not noSqueeze[1] and momentum < 0

atr = ta.atr(atrLen)

if releaseLong
    strategy.entry("Long", strategy.long)
if releaseShort
    strategy.entry("Short", strategy.short)

if useStop
    if strategy.position_size > 0
        strategy.exit("LX", "Long", stop=strategy.position_avg_price - slMult * atr, limit=strategy.position_avg_price + tpMult * atr)
    if strategy.position_size < 0
        strategy.exit("SX", "Short", stop=strategy.position_avg_price + slMult * atr, limit=strategy.position_avg_price - tpMult * atr)

plotshape(releaseLong, "Long Release", shape.triangleup, location.belowbar, color.new(bullColorInput, 0), size=size.tiny, text="L")
plotshape(releaseShort, "Short Release", shape.triangledown, location.abovebar, color.new(bearColorInput, 0), size=size.tiny, text="S")
bgcolor(squeeze ? color.new(#2a2e39, 93) : na, title="Squeeze Regime")
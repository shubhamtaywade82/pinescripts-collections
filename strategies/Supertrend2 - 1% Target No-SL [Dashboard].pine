//@version=6
strategy("Supertrend2 - 1% Target No-SL [Dashboard]",
     overlay=true,
     initial_capital=100000,
     default_qty_type=strategy.percent_of_equity,
     default_qty_value=10,          // Reduced from 100% for survivability
     commission_type=strategy.commission.percent,
     commission_value=0.1,
     calc_on_every_tick=true,
     max_lines_count=500,
     max_labels_count=500)

// ═════════════════════════════════════════════════════════════════════════════
// 1. INPUTS
// ═════════════════════════════════════════════════════════════════════════════
atrPeriod    = input.int(10, "ATR Length", minval=1, group="Supertrend Settings")
factor       = input.float(3.0, "Factor", step=0.1, group="Supertrend Settings")
tpPercent    = input.float(1.0, "Profit Target %", step=0.1, group="Target Settings")
useTimeExit  = input.bool(true, "Enable Time-Based Exit", group="Safety Settings (Stuck Trades)")
maxDays      = input.int(30, "Max Days to Hold", minval=1, group="Safety Settings (Stuck Trades)")
useBreakeven = input.bool(true, "Exit at Breakeven after Max Days", group="Safety Settings (Stuck Trades)")
useTrailing  = input.bool(false, "Trail Profit if Trend is Strong", group="Exit Settings")
trailPercent = input.float(0.5, "Trailing Offset %", step=0.1, group="Exit Settings")
showTable    = input.bool(true, "Show Performance Table", group="Dashboard")
tablePos     = input.string("Top Right", "Table Position", options=["Top Right", "Top Left", "Bottom Right", "Bottom Left"], group="Dashboard")

// ═════════════════════════════════════════════════════════════════════════════
// 2. SUPERTREND2 SIGNAL GENERATION
// ═════════════════════════════════════════════════════════════════════════════
[stValue, direction] = ta.supertrend(factor, atrPeriod)

// v6 Strict Boolean Logic — explicit comparisons, no implicit casting
bool isLongSignal  = direction < 0 and direction[1] >= 0
bool isShortSignal = direction > 0 and direction[1] <= 0

// ═════════════════════════════════════════════════════════════════════════════
// 3. VISUALS
// ═════════════════════════════════════════════════════════════════════════════
plot(stValue, color=direction < 0 ? color.green : color.red, linewidth=2, title="Supertrend")
bgcolor(direction < 0 ? color.new(color.green, 90) : color.new(color.red, 90), title="Trend Bias")

plotshape(isLongSignal,  style=shape.triangleup,   location=location.belowbar,
     color=color.green, size=size.small, title="Long Signal")
plotshape(isShortSignal, style=shape.triangledown, location=location.abovebar,
     color=color.red,   size=size.small, title="Short Signal")

// ═════════════════════════════════════════════════════════════════════════════
// 4. EXECUTION LOGIC (v6: wrapped in if blocks — no 'when' parameter)
// ═════════════════════════════════════════════════════════════════════════════
if isLongSignal and strategy.position_size == 0
    strategy.entry("Long", strategy.long, comment="Long Entry")

if isShortSignal and strategy.position_size == 0
    strategy.entry("Short", strategy.short, comment="Short Entry")

// ═════════════════════════════════════════════════════════════════════════════
// 5. EXIT LOGIC: 1% PROFIT TARGET & TRAILING
// ═════════════════════════════════════════════════════════════════════════════
if strategy.position_size > 0
    float longTP = strategy.position_avg_price * (1 + tpPercent / 100)
    
    if not useTrailing
        strategy.exit("TP Long", from_entry="Long", limit=longTP, comment="Long TP")
    else
        // Trailing logic: activate trail after reaching 1%
        strategy.exit("Trail Long", from_entry="Long", stop=na, limit=na, 
             trail_price=longTP, trail_offset=(strategy.position_avg_price * trailPercent / 100) / syminfo.mintick,
             comment="Long Trail")

if strategy.position_size < 0
    float shortTP = strategy.position_avg_price * (1 - tpPercent / 100)
    
    if not useTrailing
        strategy.exit("TP Short", from_entry="Short", limit=shortTP, comment="Short TP")
    else
        // Trailing logic: activate trail after reaching 1%
        strategy.exit("Trail Short", from_entry="Short", stop=na, limit=na,
             trail_price=shortTP, trail_offset=(strategy.position_avg_price * trailPercent / 100) / syminfo.mintick,
             comment="Short Trail")

// ── Stuck Trade Recovery ──
int barsInTrade = strategy.position_size != 0 ? bar_index - strategy.opentrades.entry_bar_index(0) : 0
float daysInTrade = (barsInTrade * timeframe.multiplier) / 1440 // Rough calc for daily/min charts

if useTimeExit and strategy.position_size != 0
    bool timeExpired = barsInTrade > (maxDays * (1440 / (timeframe.isintraday ? timeframe.multiplier : 1440)))
    
    // Scenario A: Hard Exit after X days (Accept the loss)
    if not useBreakeven and timeExpired
        strategy.close_all(comment="Time Exit")
        
    // Scenario B: Soft Exit (Wait for price to return to entry after X days)
    if useBreakeven and timeExpired
        if strategy.position_size > 0 and close >= strategy.position_avg_price
            strategy.close_all(comment="Breakeven Exit")
        if strategy.position_size < 0 and close <= strategy.position_avg_price
            strategy.close_all(comment="Breakeven Exit")

// ═════════════════════════════════════════════════════════════════════════════
// 6. PERFORMANCE DASHBOARD (Table)
// ═════════════════════════════════════════════════════════════════════════════
if showTable
    // Map string input to table position enum
    tablePosition = tablePos == "Top Right" ? position.top_right : tablePos == "Top Left" ? position.top_left : tablePos == "Bottom Right" ? position.bottom_right : position.bottom_left

    var table perfTable = table.new(tablePosition, 2, 10,
         bgcolor=color.new(color.black, 10),
         frame_color=color.new(color.gray, 50),
         frame_width=1,
         border_color=color.new(color.gray, 50),
         border_width=1)

    // ── Max Drawdown (manual tracking) ──
    var float peakEquity = 0.0
    var float maxDrawdownPct = 0.0
    peakEquity := math.max(peakEquity, strategy.equity)
    float currentDD = peakEquity > 0 ? ((peakEquity - strategy.equity) / peakEquity) * 100 : 0.0
    maxDrawdownPct := math.max(maxDrawdownPct, currentDD)

    // ── Color Helpers ──
    color cGreen = color.new(color.green, 20)
    color cRed   = color.new(color.red, 20)
    color cWhite = color.white
    color cGray  = color.gray

    // ── Render Table (only on last bar to save resources) ──
    if barstate.islast
        // ── Raw Metrics ──
        int totalTrades   = strategy.closedtrades
        int winningTrades = strategy.wintrades
        int losingTrades  = strategy.losstrades
        float grossProfit = strategy.grossprofit
        float grossLoss   = strategy.grossloss
        float netProfit   = strategy.netprofit
        float openProfit  = strategy.openprofit

        // ── Derived Metrics ──
        float winRate      = totalTrades > 0 ? (winningTrades / totalTrades) * 100 : 0.0
        float profitFactor = grossLoss != 0.0 ? grossProfit / math.abs(grossLoss) : (grossProfit > 0 ? 999.99 : 0.0)
        float avgTrade     = totalTrades > 0 ? netProfit / totalTrades : 0.0
        float winLossRatio = losingTrades > 0 ? winningTrades / losingTrades : (winningTrades > 0 ? 999.99 : 0.0)

        // Header
        table.cell(perfTable, 0, 0, "📊 PERFORMANCE", text_color=cWhite, text_size=size.small)
        table.cell(perfTable, 1, 0, "", text_color=cWhite, text_size=size.small)

        // Net Profit
        table.cell(perfTable, 0, 1, "Net Profit",     text_color=cGray, text_size=size.tiny)
        table.cell(perfTable, 1, 1, str.tostring(netProfit, "#.##"),
             text_color=netProfit >= 0 ? cGreen : cRed, text_size=size.tiny)

        // Open P&L
        table.cell(perfTable, 0, 2, "Open P&L",       text_color=cGray, text_size=size.tiny)
        table.cell(perfTable, 1, 2, str.tostring(openProfit, "#.##"),
             text_color=openProfit >= 0 ? cGreen : cRed, text_size=size.tiny)

        // Total Trades
        table.cell(perfTable, 0, 3, "Total Trades",   text_color=cGray, text_size=size.tiny)
        table.cell(perfTable, 1, 3, str.tostring(totalTrades), text_color=cWhite, text_size=size.tiny)

        // Win Rate
        table.cell(perfTable, 0, 4, "Win Rate",       text_color=cGray, text_size=size.tiny)
        table.cell(perfTable, 1, 4, str.tostring(winRate, "#.##") + "%", text_color=cGreen, text_size=size.tiny)

        // Profit Factor
        table.cell(perfTable, 0, 5, "Profit Factor",  text_color=cGray, text_size=size.tiny)
        table.cell(perfTable, 1, 5, str.tostring(profitFactor, "#.##"),
             text_color=profitFactor >= 1.0 ? cGreen : cRed, text_size=size.tiny)

        // W/L Ratio
        table.cell(perfTable, 0, 6, "W/L Ratio",      text_color=cGray, text_size=size.tiny)
        table.cell(perfTable, 1, 6, str.tostring(winLossRatio, "#.##"),
             text_color=winLossRatio >= 1.0 ? cGreen : cRed, text_size=size.tiny)

        // Avg Trade
        table.cell(perfTable, 0, 7, "Avg Trade",      text_color=cGray, text_size=size.tiny)
        table.cell(perfTable, 1, 7, str.tostring(avgTrade, "#.##"),
             text_color=avgTrade >= 0 ? cGreen : cRed, text_size=size.tiny)

        // Max Drawdown
        table.cell(perfTable, 0, 8, "Max Drawdown",   text_color=cGray, text_size=size.tiny)
        table.cell(perfTable, 1, 8, str.tostring(maxDrawdownPct, "#.##") + "%", text_color=cRed, text_size=size.tiny)

        // Current Position
        string posText = strategy.position_size > 0 ? "🟢 LONG" :
                         strategy.position_size < 0 ? "🔴 SHORT" : "⚪ FLAT"
        color posColor = strategy.position_size > 0 ? cGreen :
                         strategy.position_size < 0 ? cRed : cGray
        table.cell(perfTable, 0, 9, "Position",       text_color=cGray, text_size=size.tiny)
        table.cell(perfTable, 1, 9, posText,          text_color=posColor, text_size=size.tiny)

// ═════════════════════════════════════════════════════════════════════════════
// 7. ALERTS (Optional — for webhook automation)
// ═════════════════════════════════════════════════════════════════════════════
if isLongSignal
    alert("Supertrend Long: Long Entry Signal", alert.freq_once_per_bar)

if isShortSignal
    alert("Supertrend Short: Short Entry Signal", alert.freq_once_per_bar)

// Ported from pinescript-agents/examples/simple/bollinger-squeeze.pine for local testing in pinescripts-collections.

//@version=6
indicator("Bollinger Band Squeeze Detector [Agent Example]", shorttitle="BBSqzAE", overlay=false, scale=scale.right)

bbLength = input.int(20, "BB Length", minval=1, group="Bollinger Bands")
bbMult = input.float(2.0, "BB Multiplier", minval=0.1, step=0.1, group="Bollinger Bands")

kcLength = input.int(20, "KC Length", minval=1, group="Keltner Channels")
kcMult = input.float(1.5, "KC Multiplier", minval=0.1, step=0.1, group="Keltner Channels")

showMomentum = input.bool(true, "Show Momentum", group="Display")
normalizeMomentum = input.bool(true, "Normalize Momentum (ATR)", group="Display")
momentumClamp = input.float(3.0, "Momentum Clamp", minval=0.5, step=0.5, group="Display")
showSqueezeCount = input.bool(true, "Show Squeeze Count", group="Display")
bullColorInput = input.color(#089981, "Bullish Color", group="Visuals")
bearColorInput = input.color(#f23645, "Bearish Color", group="Visuals")
neutralColorInput = input.color(color.new(#2a2e39, 0), "Neutral Color", group="Visuals")

basis = ta.sma(close, bbLength)
dev = bbMult * ta.stdev(close, bbLength)
bbUpper = basis + dev
bbLower = basis - dev

kcMA = ta.ema(close, kcLength)
kcRange = ta.atr(kcLength)
kcUpper = kcMA + kcRange * kcMult
kcLower = kcMA - kcRange * kcMult

squeeze = bbUpper < kcUpper and bbLower > kcLower
noSqueeze = bbUpper > kcUpper or bbLower < kcLower

donchianMid = (ta.highest(high, kcLength) + ta.lowest(low, kcLength)) / 2
momentum = close - donchianMid

var int squeezeCount = 0
squeezeCount := squeeze ? squeezeCount + 1 : 0

stateValue = squeeze ? 1.0 : -1.0
stateColor = squeeze ? color.new(bearColorInput, 70) : color.new(bullColorInput, 70)
plot(stateValue, "Squeeze State", color=stateColor, style=plot.style_columns, linewidth=1)

momUpStrong = momentum > 0 and momentum > momentum[1]
momDnStrong = momentum < 0 and momentum < momentum[1]
momentumColor = momentum > 0 ? (momUpStrong ? color.new(bullColorInput, 0) : color.new(bullColorInput, 50)) : (momDnStrong ? color.new(bearColorInput, 0) : color.new(bearColorInput, 50))
atrNorm = ta.atr(kcLength)
momentumBase = normalizeMomentum and atrNorm > 0 ? momentum / atrNorm : momentum
momentumCapped = math.max(-momentumClamp, math.min(momentumClamp, momentumBase))
plot(showMomentum ? momentumCapped : na, "Momentum", momentumColor, style=plot.style_histogram, linewidth=3)

hline(0, "Zero", color=color.new(neutralColorInput, 50), linestyle=hline.style_dotted)

var table infoTable = table.new(position.top_right, 2, 2, bgcolor=color.new(#0b0e14, 25), border_color=color.new(neutralColorInput, 70))
if showSqueezeCount and barstate.islast
    table.cell(infoTable, 0, 0, "Status", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 0, squeeze ? "SQUEEZE" : "NO SQUEEZE", text_color=squeeze ? bearColorInput : bullColorInput, text_size=size.small)
    if squeeze
        table.cell(infoTable, 0, 1, "Duration", text_color=color.white, text_size=size.small)
        table.cell(infoTable, 1, 1, str.tostring(squeezeCount) + " bars", text_color=color.yellow, text_size=size.small)

alertcondition(squeeze and not squeeze[1], "Squeeze Start", "Bollinger Squeeze Started")
alertcondition(noSqueeze and not noSqueeze[1], "Squeeze Release", "Bollinger Squeeze Released - Potential Breakout")
alertcondition(squeeze and squeezeCount == 10, "Extended Squeeze", "Squeeze lasting 10+ bars - Major move likely")

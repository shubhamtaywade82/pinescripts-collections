// Ported from pinescript-agents/examples/simple/support-resistance-basic.pine for local testing in pinescripts-collections.

//@version=6
indicator("Support & Resistance Basic [Agent Example]", "S&R · AE", overlay=true, max_lines_count=50)

pivot_length = input.int(10, "Pivot Length", minval=5, maxval=50, group="Settings")
line_extend = input.int(20, "Line Extension", minval=10, maxval=100, group="Settings")
support_color = input.color(#089981, "Support Color", group="Colors")
resistance_color = input.color(#f23645, "Resistance Color", group="Colors")
line_width = input.int(2, "Line Width", minval=1, maxval=4, group="Display")
show_level_labels = input.bool(true, "Show Level Labels", group="Display")
extend_left = input.bool(true, "Extend Lines Left", group="Display")
max_levels = input.int(10, "Max Levels per Side", minval=1, maxval=50, group="Display")

var line[] support_lines = array.new<line>()
var line[] resistance_lines = array.new<line>()
var label[] support_labels = array.new<label>()
var label[] resistance_labels = array.new<label>()

pivot_high = ta.pivothigh(high, pivot_length, pivot_length)
pivot_low = ta.pivotlow(low, pivot_length, pivot_length)

cleanup_lines(lines_array, max_lines) =>
    while array.size(lines_array) > max_lines
        old_line = array.shift(lines_array)
        line.delete(old_line)

cleanup_labels(labels_array, max_labels) =>
    while array.size(labels_array) > max_labels
        old_label = array.shift(labels_array)
        label.delete(old_label)

if barstate.isconfirmed
    if not na(pivot_low)
        support_level = pivot_low
        start_bar = bar_index - pivot_length
        end_bar = extend_left ? bar_index : bar_index + line_extend
        line_extend_mode = extend_left ? extend.left : extend.none
        support_line = line.new(start_bar, support_level, end_bar, support_level, color=support_color, width=line_width, style=line.style_solid, extend=line_extend_mode)
        array.push(support_lines, support_line)
        if show_level_labels
            support_text = "S " + str.tostring(support_level, "#.##")
            support_label = label.new(end_bar, support_level, text=support_text, color=support_color, textcolor=color.white, size=size.tiny, style=label.style_label_left)
            array.push(support_labels, support_label)
        cleanup_lines(support_lines, max_levels)
        cleanup_labels(support_labels, max_levels)
    if not na(pivot_high)
        resistance_level = pivot_high
        start_bar = bar_index - pivot_length
        end_bar = extend_left ? bar_index : bar_index + line_extend
        line_extend_mode = extend_left ? extend.left : extend.none
        resistance_line = line.new(start_bar, resistance_level, end_bar, resistance_level, color=resistance_color, width=line_width, style=line.style_solid, extend=line_extend_mode)
        array.push(resistance_lines, resistance_line)
        if show_level_labels
            resistance_text = "R " + str.tostring(resistance_level, "#.##")
            resistance_label = label.new(end_bar, resistance_level, text=resistance_text, color=resistance_color, textcolor=color.white, size=size.tiny, style=label.style_label_left)
            array.push(resistance_labels, resistance_label)
        cleanup_lines(resistance_lines, max_levels)
        cleanup_labels(resistance_labels, max_levels)

plotshape(pivot_high, style=shape.labeldown, location=location.abovebar, color=color.new(resistance_color, 0), textcolor=color.white, text="R", size=size.small)
plotshape(pivot_low, style=shape.labelup, location=location.belowbar, color=color.new(support_color, 0), textcolor=color.white, text="S", size=size.small)

alertcondition(not na(pivot_high), "Resistance Level", "New resistance level detected")
alertcondition(not na(pivot_low), "Support Level", "New support level detected")
